{
  "name": "test-reporter",
  "version": "1.0.0",
  "description": "Auto-discover, run tests, and generate beautiful HTML reports with Jira integration",
  "type": "module",
  "bin": {
    "test-reporter": "./bin/cli.js"
  },
  "main": "src/index.js",
  "scripts": {
    "test": "node bin/cli.js",
    "test:verbose": "node bin/cli.js --verbose",
    "test:watch": "node bin/cli.js --watch"
  },
  "keywords": [
    "testing",
    "test-runner",
    "vitest",
    "reporter",
    "html-report",
    "jira",
    "ci-cd"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "glob": "^10.5.0",
    "open": "^10.1.0"
  },
  "peerDependencies": {
    "vitest": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  }
}
